{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.nvm/versions/node/v22.22.0/lib/node_modules/oh-my-codex/dist/scripts/codex-native-hook.js\"",
            "statusMessage": "Loading OMX session context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.nvm/versions/node/v22.22.0/lib/node_modules/oh-my-codex/dist/scripts/codex-native-hook.js\"",
            "statusMessage": "Running OMX Bash preflight"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.nvm/versions/node/v22.22.0/lib/node_modules/oh-my-codex/dist/scripts/codex-native-hook.js\"",
            "statusMessage": "Running OMX Bash review"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.nvm/versions/node/v22.22.0/lib/node_modules/oh-my-codex/dist/scripts/codex-native-hook.js\"",
            "statusMessage": "Applying OMX prompt routing"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/root/.nvm/versions/node/v22.22.0/lib/node_modules/oh-my-codex/dist/scripts/codex-native-hook.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
